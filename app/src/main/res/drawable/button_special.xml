<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/warm_special_start"
                android:endColor="@color/warm_special_end"
                android:angle="90" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/warm_accent_light" />
        </shape>
    </item>
</ripple>