<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="12dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitulu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/titulu"
        android:textAlignment="center"
        android:textColor="@color/warm_accent_light"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Input field -->
    <EditText
        android:id="@+id/etInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/edittext_rounded"
        android:cursorVisible="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:fontFamily="monospace"
        android:gravity="end"
        android:hint="@string/input_hint"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:textColor="@color/white"
        android:textColorHint="@color/text_hint"
        android:textSize="24sp"
        android:importantForAutofill="no"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulu" />

    <!-- Result display -->
    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/result_background"
        android:fontFamily="monospace"
        android:gravity="center"
        android:hint="@string/Resultado"
        android:padding="20dp"
        android:textAlignment="center"
        android:textColor="@color/accent_warm"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etInput" />

    <!-- ScrollView for buttons -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResultado">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/buttonFlow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="btnClearAll,btnClear,btnDivisao,btnMultiplicacao,btn7,btn8,btn9,btnSubtracao,btn4,btn5,btn6,btnSoma,btn1,btn2,btn3,btnEquals,btn0,btnDecimal,btnSqrt,btnPercent,btnSin,btnCos,btnTan,btnLn,btnLog,btnExp,btnPower,btnNthRoot,btnOpenParen,btnCloseParen,btnPi,btnE"
                app:flow_maxElementsWrap="4"
                app:flow_wrapMode="aligned"
                app:flow_horizontalGap="8dp"
                app:flow_verticalGap="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Row 1 -->
            <Button android:id="@+id/btnClearAll" style="@style/SpecialButton" android:text="@string/btn_clear_all" android:onClick="onClearAllClick" />
            <Button android:id="@+id/btnClear" style="@style/SpecialButton" android:text="@string/btn_clear" android:onClick="onClearClick" />
            <Button android:id="@+id/btnDivisao" style="@style/OperationButton" android:text="@string/btn_divide" android:onClick="onOperationClick" />
            <Button android:id="@+id/btnMultiplicacao" style="@style/OperationButton" android:text="@string/btn_multiply" android:onClick="onOperationClick" />

            <!-- Row 2 -->
            <Button android:id="@+id/btn7" style="@style/NumberButton" android:text="@string/btn_7" android:onClick="onNumberClick" />
            <Button android:id="@+id/btn8" style="@style/NumberButton" android:text="@string/btn_8" android:onClick="onNumberClick" />
            <Button android:id="@+id/btn9" style="@style/NumberButton" android:text="@string/btn_9" android:onClick="onNumberClick" />
            <Button android:id="@+id/btnSubtracao" style="@style/OperationButton" android:text="@string/btn_subtract" android:onClick="onOperationClick" />

            <!-- Row 3 -->
            <Button android:id="@+id/btn4" style="@style/NumberButton" android:text="@string/btn_4" android:onClick="onNumberClick" />
            <Button android:id="@+id/btn5" style="@style/NumberButton" android:text="@string/btn_5" android:onClick="onNumberClick" />
            <Button android:id="@+id/btn6" style="@style/NumberButton" android:text="@string/btn_6" android:onClick="onNumberClick" />
            <Button android:id="@+id/btnSoma" style="@style/OperationButton" android:text="@string/btn_add" android:onClick="onOperationClick" />

            <!-- Row 4 -->
            <Button android:id="@+id/btn1" style="@style/NumberButton" android:text="@string/btn_1" android:onClick="onNumberClick" />
            <Button android:id="@+id/btn2" style="@style/NumberButton" android:text="@string/btn_2" android:onClick="onNumberClick" />
            <Button android:id="@+id/btn3" style="@style/NumberButton" android:text="@string/btn_3" android:onClick="onNumberClick" />
            <Button android:id="@+id/btnEquals" style="@style/SpecialButton" android:text="@string/btn_equals" android:onClick="onEqualsClick" />

            <!-- Row 5 -->
            <Button android:id="@+id/btn0" style="@style/NumberButton" android:text="@string/btn_0" android:onClick="onNumberClick" />
            <Button android:id="@+id/btnDecimal" style="@style/NumberButton" android:text="@string/btn_decimal" android:onClick="onNumberClick" />
            <Button android:id="@+id/btnSqrt" style="@style/OperationButton" android:text="@string/btn_sqrt" android:onClick="onSqrtClick" />
            <Button android:id="@+id/btnPercent" style="@style/OperationButton" android:text="@string/btn_percent" android:onClick="onPercentClick" />

            <!-- Row 6 -->
            <Button android:id="@+id/btnSin" style="@style/OperationButton" android:text="sin" android:onClick="onSinClick" />
            <Button android:id="@+id/btnCos" style="@style/OperationButton" android:text="cos" android:onClick="onCosClick" />
            <Button android:id="@+id/btnTan" style="@style/OperationButton" android:text="tan" android:onClick="onTanClick" />
            <Button android:id="@+id/btnLn" style="@style/OperationButton" android:text="ln" android:onClick="onLnClick" />

            <!-- Row 7 -->
            <Button android:id="@+id/btnLog" style="@style/OperationButton" android:text="log" android:onClick="onLogClick" />
            <Button android:id="@+id/btnExp" style="@style/OperationButton" android:text="eˣ" android:onClick="onExpClick" />
            <Button android:id="@+id/btnPower" style="@style/OperationButton" android:text="xʸ" android:onClick="onPowerClick" />
            <Button android:id="@+id/btnNthRoot" style="@style/OperationButton" android:text="ⁿ√x" android:onClick="onNthRootClick" />

            <!-- Row 8 -->
            <Button android:id="@+id/btnOpenParen" style="@style/OperationButton" android:text="(" android:onClick="onParenClick" />
            <Button android:id="@+id/btnCloseParen" style="@style/OperationButton" android:text=")" android:onClick="onParenClick" />
            <Button android:id="@+id/btnPi" style="@style/OperationButton" android:text="π" android:onClick="onPiClick" />
            <Button android:id="@+id/btnE" style="@style/OperationButton" android:text="e" android:onClick="onEClick" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>