<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Structured Button Style -->
    <style name="NumberButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_margin">1dp</item>
        <item name="android:background">@drawable/button_futuristic</item>
        <item name="android:textColor">@color/color_num_text</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="OperationButton" parent="NumberButton">
        <item name="android:background">@drawable/button_operation</item>
        <item name="android:textColor">@color/color_op_text</item>
    </style>

    <style name="SpecialButton" parent="NumberButton">
        <item name="android:background">@drawable/button_special</item>
        <item name="android:textColor">@color/color_spec_text</item>
    </style>
</resources>